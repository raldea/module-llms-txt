<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="angeo" translate="label" sortOrder="500" class="angeo-tab">
            <label>Angeo</label>
        </tab>

        <section id="angeo_llms" translate="label" sortOrder="10"
                 showInDefault="1" showInWebsite="1" showInStore="1">
            <label>LLMs.txt</label>
            <tab>angeo</tab>
            <resource>Angeo_LlmsTxt::config</resource>

            <!-- ─── General ─── -->
            <group id="general" translate="label" sortOrder="10"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General</label>

                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Enables llms.txt / llms-full.txt / JSONL generation and serving.</comment>
                </field>

                <field id="exclude_store" translate="label comment" type="select" sortOrder="20"
                       showInDefault="0" showInWebsite="1" showInStore="1">
                    <label>Exclude This Scope</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>When yes, skip generation for this store (or all stores under this website if set at website scope).</comment>
                </field>

                <field id="store_summary" translate="label comment" type="textarea" sortOrder="30"
                       showInDefault="0" showInWebsite="0" showInStore="1">
                    <label>Store Summary</label>
                    <comment><![CDATA[Optional one-line summary used as the spec-compliant blockquote on llms.txt. If empty, the store's <em>Default Description</em> (Design → HTML Head) is used.]]></comment>
                </field>
            </group>

            <!-- ─── Actions ─── -->
            <group id="actions" translate="label" sortOrder="15"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Actions</label>

                <field id="generate" translate="label" type="button" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Generate</label>
                    <frontend_model>Angeo\LlmsTxt\Block\Adminhtml\System\Config\GenerateButton</frontend_model>
                </field>

                <field id="status_panel" translate="label" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Status</label>
                    <frontend_model>Angeo\LlmsTxt\Block\Adminhtml\System\Config\StatusPanel</frontend_model>
                </field>
            </group>

            <!-- ─── Content selection ─── -->
            <group id="content" translate="label" sortOrder="20"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Content</label>

                <field id="include_categories" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Include Categories</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="include_cms" translate="label" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Include CMS Pages</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="include_products" translate="label" type="select" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Include Products</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="products_under_optional" translate="label comment" type="select" sortOrder="40"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Products under "## Optional"</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment><![CDATA[Per llmstxt.org spec, links under <code>## Optional</code> can be dropped by AI clients under context-budget pressure. Strongly recommended for stores with many products.]]></comment>
                    <depends>
                        <field id="include_products">1</field>
                    </depends>
                </field>

                <field id="product_limit" translate="label comment" type="text" sortOrder="50"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Product Limit</label>
                    <validate>validate-digits</validate>
                    <comment>Cap the number of products. 0 = unlimited.</comment>
                    <depends>
                        <field id="include_products">1</field>
                    </depends>
                </field>

                <field id="exclude_out_of_stock" translate="label" type="select" sortOrder="60"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Exclude Out-of-Stock Products</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="include_products">1</field>
                    </depends>
                </field>

                <field id="cms_exclude_identifiers" translate="label comment" type="textarea" sortOrder="70"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>CMS Identifiers to Exclude</label>
                    <comment><![CDATA[Comma- or newline-separated CMS page identifiers. Defaults: <code>no-route, enable-cookies, privacy-policy-cookie-restriction-mode</code>]]></comment>
                    <depends>
                        <field id="include_cms">1</field>
                    </depends>
                </field>

                <field id="customer_group_id" translate="label comment" type="select" sortOrder="80"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Customer Group for Pricing</label>
                    <source_model>Angeo\LlmsTxt\Model\Config\Source\CustomerGroup</source_model>
                    <comment>Product prices reflect this group's final price (special prices, group prices). Default: NOT LOGGED IN.</comment>
                </field>
            </group>

            <!-- ─── Output formats ─── -->
            <group id="formats" translate="label" sortOrder="30"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Output Formats</label>

                <field id="generate_llms_txt" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Generate llms.txt</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Spec-compliant, compact markdown.</comment>
                </field>

                <field id="generate_llms_full_txt" translate="label" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Generate llms-full.txt</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Same sections as llms.txt, but with full sanitized descriptions inline. Can be 5–50× larger.</comment>
                </field>

                <field id="generate_jsonl" translate="label" type="select" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Generate JSONL</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>One JSON record per line; for vector indexing / embedding pipelines.</comment>
                </field>

                <field id="generate_md_mirror" translate="label" type="select" sortOrder="40"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Serve /url-key.md Mirrors</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment><![CDATA[When yes, serves a clean Markdown version of every product/category/CMS page at <code>{url}.md</code>. Generated on the fly — no extra storage.]]></comment>
                </field>
            </group>

            <!-- ─── Sanitizer (Page Builder!) ─── -->
            <group id="sanitizer" translate="label" sortOrder="40"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Content Sanitization</label>

                <field id="resolve_directives" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Resolve CMS Directives</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment><![CDATA[Renders <code>{{widget}}</code>, <code>{{block}}</code>, <code>{{var}}</code>, and <code>{{store}}</code> directives via Magento's frontend filter before stripping HTML. Prevents directive source leaking into llms.txt.]]></comment>
                </field>

                <field id="page_builder_strategy" translate="label comment" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Page Builder Strategy</label>
                    <source_model>Angeo\LlmsTxt\Model\Config\Source\PageBuilderStrategy</source_model>
                    <comment><![CDATA[How to handle elements with <code>data-content-type</code> attributes (Page Builder output). Use <strong>Exclude</strong> for typical AEO; <strong>Allow</strong> for strict text-only mode.]]></comment>
                </field>

                <field id="page_builder_excluded_types" translate="label comment" type="textarea" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Excluded Content-Types</label>
                    <comment><![CDATA[Comma- or newline-separated <code>data-content-type</code> values to DROP under the <em>Exclude</em> strategy. Defaults: <code>products, banner, slider, slide, video, map, buttons, button-item, block, dynamic-block, divider, spacer</code>. Known types: <code>row, column-group, column, tabs, tab-item, text, heading, html, image, video, map, divider, spacer, buttons, button-item, banner, slider, slide, products, block, dynamic-block</code>.]]></comment>
                    <depends>
                        <field id="page_builder_strategy">exclude</field>
                    </depends>
                </field>

                <field id="page_builder_allowed_types" translate="label comment" type="textarea" sortOrder="40"
                       showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Allowed Content-Types</label>
                    <comment><![CDATA[Comma- or newline-separated <code>data-content-type</code> values to KEEP under the <em>Allow</em> strategy. Defaults: <code>text, heading, html, tabs, tab-item, row, column, column-group</code>.]]></comment>
                    <depends>
                        <field id="page_builder_strategy">allow</field>
                    </depends>
                </field>
            </group>

            <!-- ─── URL ─── -->
            <group id="url" translate="label" sortOrder="25"
                   showInDefault="1" showInWebsite="1" showInStore="0">
                <label>URL</label>

                <field id="append_store_code" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Append Store Code to URL</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>When enabled, the store code is appended to the base URL for llms.txt links (e.g. /gscaes). Disable when the store base URL already contains a unique path segment.</comment>
                </field>
            </group>

            <!-- ─── Performance ─── -->
            <group id="performance" translate="label" sortOrder="50"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Performance</label>

                <field id="collection_page_size" translate="label comment" type="text" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Collection Page Size</label>
                    <validate>validate-digits validate-digits-range digits-range-0-1000000</validate>
                    <comment>Number of products loaded per collection page during streaming. Default 1000. Lower this if you hit memory limits.</comment>
                </field>
            </group>

            <!-- ─── HTTP ─── -->
            <group id="http" translate="label" sortOrder="60"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>HTTP Caching</label>

                <field id="cache_ttl_seconds" translate="label comment" type="text" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Cache-Control TTL (seconds)</label>
                    <validate>validate-digits</validate>
                    <comment><![CDATA[Sent as <code>Cache-Control: public, max-age=</code> on the served files. Default 3600.]]></comment>
                </field>
            </group>

            <!-- ─── Cron ─── -->
            <group id="cron" translate="label" sortOrder="70"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Schedule</label>

                <field id="schedule" translate="label comment" type="text" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Cron Expression</label>
                    <comment><![CDATA[Standard cron expression. Default: <code>0 2 * * *</code> (daily at 02:00 server time).]]></comment>
                </field>
            </group>
        </section>
    </system>
</config>
